# Copy to .env before running docker compose.
# Do not commit .env.

# Browser/desktop app token for http://localhost:8080/app.
MAGI_AGENT_SERVER_TOKEN=change-me-local-token

# Local OpenAI-compatible model server defaults.
# Ollama on the host machine:
OPENAI_BASE_URL=http://host.docker.internal:11434/v1
OPENAI_API_KEY=

# Direct routing lets Magi talk to configured providers without hosted Magi Cloud.
MAGI_ROUTING_MODE=direct
MAGI_MODEL=llama3.1

# Optional hosted provider keys. Leave blank if unused.
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
FIREWORKS_API_KEY=
