# =============================================================================
# Magi Agent — "full-ON dogfood" environment profile
# =============================================================================
#
# Operator decision: the sole operator wants EVERY intended governance / harness
# module to actually RUN, on BOTH the local CLI ("magi agent", cli/engine path)
# AND the canary/hosted serve (gate5b path).
#
# This file is CONFIG, not a code-default change. It flips NO repo *.py default.
# Sourcing it sets explicit env values; un-setting it (a fresh shell) restores
# byte-identical default-OFF behavior, so the default-OFF-presuming test suite
# stays green.
#
# USAGE
#   Local CLI / serve:   set -a; source scripts/dogfood-full-on.env; set +a
#                        magi agent ...        # or: magi-agent serve ...
#   Canary / hosted:     inject these as the pod/container env (the
#                        MAGI_GATE5B_GOVERNANCE_ENABLED=1 line is what makes the
#                        gate5b serving path run the same governance as the CLI).
#
# SEMANTICS PRIMER (why two shapes of "on")
#   * profile-aware flags (kind="profile_bool", env._runtime_feature_enabled):
#     unset => ON in the full profile, OFF under MAGI_RUNTIME_PROFILE=safe/eval.
#     Setting MAGI_RUNTIME_PROFILE=full (below) already turns these ON; we ALSO
#     set each one explicitly so the value is self-documenting and survives any
#     reader that does not go through the local_defaults setdefault overlay.
#   * strict opt-in flags (kind="bool", default-OFF): MAGI_RUNTIME_PROFILE NEVER
#     auto-enables these. The profile is inert for them — they MUST be listed
#     here explicitly. This is the real "turn everything on" payload.
#
# RISK NOTES (set ON anyway, per the operator's explicit "turn everything on")
#   * MAGI_DOCUMENT_AUTHORING_COVERAGE=block — HARD-BLOCKS a document turn whose
#     DocumentCoverage record is not "pass" (highest false-block risk). Use
#     "advisory" instead of "block" to measure first.
#   * MAGI_SELF_REVIEW_ENABLED=1 (+LIVE) — spends an extra model pass after each
#     turn (latency + token cost).
#   * MAGI_RESEARCH_GOVERNANCE_MODE=enforce — one bounded corrective re-prompt on
#     the deterministic cited-without-source class (near-zero FP; still a re-run).
#   * MAGI_FACT_GROUNDING_VERIFICATION_ENABLED=1 / MAGI_GA_DELIVERABLE_GATE_ENABLED=1
#     — can BLOCK a final answer that asserts an ungrounded specific value / ships
#     no artifact receipt.
#   * MAGI_CHILD_RUNNER_LIVE_ENABLED=1 — real model-backed sub-agents (cost).
#
# =============================================================================


# -----------------------------------------------------------------------------
# 0. Profile selector
# -----------------------------------------------------------------------------
# "full" is any value NOT in {safe,off,minimal,conservative,eval}; it makes
# runtime/local_defaults.apply_local_full_runtime_defaults() apply the
# profile-opt-out set and makes every profile_bool flag resolve ON. We keep it
# explicit AND list each downstream flag below so nothing is implicit.
export MAGI_RUNTIME_PROFILE=full
export MAGI_AGENT_LOCAL_FULL_RUNTIME_DEFAULTS=1


# -----------------------------------------------------------------------------
# 1. Strict opt-in GOVERNANCE / VERIFICATION gates (default-OFF; profile inert)
#    These are the heart of "turn everything on". None default ON in any profile.
# -----------------------------------------------------------------------------
# Gate5b serving-path governance (G1). Makes the canary/hosted serve attach the
# SAME control-plane plugin + run the SAME pre-final fact-grounding check as the
# local CLI. Without this line governance is cli/engine-only.
export MAGI_GATE5B_GOVERNANCE_ENABLED=1

# Live evidence gate: block an answer asserting a specific numeric/identifier
# value not present in the opened-source corpus (cli/engine AND, via the line
# above, gate5b).
export MAGI_FACT_GROUNDING_VERIFICATION_ENABLED=1

# GA deliverable completion gate: an artifact receipt must exist before finalise.
export MAGI_GA_DELIVERABLE_GATE_ENABLED=1

# Evidence-grounded critic gate before chat egress.
export MAGI_EGRESS_GATE_ENABLED=1

# Periodic in-context facts survey + plan refresh injected into the live loop.
export MAGI_FACTS_REPLAN_ENABLED=1
export MAGI_FACTS_REPLAN_INTERVAL=4
export MAGI_FACTS_REPLAN_MAX_PER_TURN=5

# Live-SWE-style tool-synthesis nudge ("create your own tools" recipe block).
export MAGI_TOOL_SYNTHESIS_NUDGE_ENABLED=1

# Document-authoring coverage gate. RISK: "block" hard-blocks failed-coverage
# document turns. Operator wants real governance -> block (use "advisory" to
# measure FP first). Legacy truthy ("1") also means block.
export MAGI_DOCUMENT_AUTHORING_COVERAGE=block

# Research governance. "enforce" = one bounded re-prompt on the deterministic
# cited-without-source class (the local full profile only sets "audit").
export MAGI_RESEARCH_GOVERNANCE_MODE=enforce

# Research_fact cross-check guidance brief + <web_research> prompt block
# (effective only with BRAVE_API_KEY + FIRECRAWL_API_KEY present).
export MAGI_RESEARCH_FACT_GUIDANCE_ENABLED=1

# Cross-verification gate over spawned-agent results.
export MAGI_CROSS_VERIFY_ENABLED=1

# First-pass sub-step enumeration nudge.
export MAGI_STEP_DECOMPOSITION_ENABLED=1

# Self-introspection InspectSelfEvidence tool + durable evidence ledgers.
# (SELF_INTROSPECTION / EVIDENCE_LEDGER_LIFECYCLE are profile-ON; reaffirmed in
#  section 4. The ledger DIR below is the strict opt-in that makes ledgers
#  durable on disk rather than lean in-memory only.)
export MAGI_EVIDENCE_LEDGER_DIR=.openmagi/evidence-ledgers


# -----------------------------------------------------------------------------
# 2. Self-review (default-OFF strict opt-in; cost noted above)
# -----------------------------------------------------------------------------
export MAGI_SELF_REVIEW_ENABLED=1
export MAGI_SELF_REVIEW_SHADOW=0
export MAGI_SELF_REVIEW_PIPELINE_ENABLED=1
export MAGI_SELF_REVIEW_LIVE_ENABLED=1
export MAGI_SELF_REVIEW_TELEMETRY_ENABLED=1

# Max-steps brake control-plane seam.
export MAGI_MAX_STEPS_BRAKE_ENABLED=1


# -----------------------------------------------------------------------------
# 3. MEMORY subsystem (master is strict default-OFF and NOT profile-aware, so
#    the full profile leaves it OFF — it MUST be turned on explicitly here).
#    Sub-flags follow the master; the cost/multi-tenancy opt-ins (soul_write,
#    vector_search, qmd auto-register) stay OFF under master-on unless set, so
#    we set the ones the operator wants ("everything on") explicitly.
# -----------------------------------------------------------------------------
export MAGI_MEMORY_ENABLED=1
export MAGI_MEMORY_WRITE_ENABLED=1
export MAGI_MEMORY_RECALL_ENABLED=1
export MAGI_MEMORY_COMPACTION_ENABLED=1
export MAGI_MEMORY_PROJECTION_ENABLED=1
export MAGI_MEMORY_WRITE_READINESS_ENABLED=1
export MAGI_MEMORY_MODE_ROUTING_ENABLED=1
export MAGI_MEMORY_QMD_LIVE_ENABLED=1
# Master-on opt-ins (explicit, stay OFF otherwise):
export MAGI_MEMORY_VECTOR_SEARCH=1
export MAGI_MEMORY_PREFER_LOCAL_SEARCH=1
export MAGI_MEMORY_LOCAL_DEV=1


# -----------------------------------------------------------------------------
# 4. Coding / resilience harness (profile-aware default-ON: reaffirmed explicit)
#    These are ON in the full profile already; setting them keeps the file the
#    single readable source of truth and immune to setdefault-bypass readers.
# -----------------------------------------------------------------------------
export MAGI_EDIT_FUZZY_MATCH_ENABLED=1
export MAGI_EDIT_FORMAT_ON_WRITE_ENABLED=1
export MAGI_EDIT_RETRY_REFLECTION_ENABLED=1
export MAGI_CODING_REPAIR_LOOP_ENABLED=1
export MAGI_LSP_DIAGNOSTICS_ENABLED=1
export MAGI_RIPGREP_ENABLED=1
export MAGI_APPLY_PATCH_ENABLED=1
export MAGI_LOOP_GUARD_ENABLED=1
export MAGI_ERROR_RECOVERY_ENABLED=1
export MAGI_OUTPUT_CONTINUATION_ENABLED=1
export MAGI_CONTEXT_COMPACTION_ENABLED=1
export MAGI_SELF_INTROSPECTION_ENABLED=1
export MAGI_EVIDENCE_LEDGER_LIFECYCLE_ENABLED=1
export MAGI_EVIDENCE_COMPLETION_GATE_ENABLED=1
export MAGI_PROVIDER_REPAIR_ENABLED=1
export MAGI_MODEL_AWARE_PROMPTS_ENABLED=1
export MAGI_TRUSTED_LOCAL_SHELL_ENABLED=1


# -----------------------------------------------------------------------------
# 5. GA live + workflow + child runner + scheduler + observability
# -----------------------------------------------------------------------------
export MAGI_GA_LIVE_ENABLED=1
export MAGI_WORKFLOW_EXECUTOR_ENABLED=1
export MAGI_CHILD_RUNNER_LIVE_ENABLED=1
# Orchestrator (section 5b) restricts the MAIN agent to read+spawn and forces
# mutation through children, so children MUST be able to mutate — the env-profile
# floor is "full", then narrowed per-task by allowedTools ∩ spawn_cap. With
# "readonly" here, NOTHING could mutate (main can't, children can't).
export MAGI_CHILD_RUNNER_TOOLSET=full
# Expose live sub-agents (SpawnAgent) on the gate5b dashboard-chat SERVE path,
# not just the local CLI/engine. MAGI_CHILD_RUNNER_LIVE_ENABLED above only
# permits child execution; without this flag the gate5b full toolhost stays
# disabled on serve (gate1a fallback) and SpawnAgent is projection-only. With it
# set, build_gate5b_full_toolhost_config_from_env derives a ready, write-EXCLUSIVE
# (read tools + SpawnAgent), scope-matched toolhost so a chat turn can spawn a
# real sub-agent. Default-OFF: unset => byte-identical serve. Caps (depth/total/
# output/toolset) are enforced inside the child_runner_boundary either
# way. REAL COST: each SpawnAgent call spawns a real model-backed turn.
export MAGI_GATE5B_LIVE_SUBAGENTS_ENABLED=1
export MAGI_SCHEDULER_EXECUTOR_ENABLED=1
export MAGI_SCHEDULER_SHADOW=0
export MAGI_GOAL_LOOP_ENABLED=1
export MAGI_OBSERVABILITY_ENABLED=1
export MAGI_OBS_HOME=.openmagi
export MAGI_SESSION_PERSISTENCE_ENABLED=1


# -----------------------------------------------------------------------------
# 5b. Main-agent-as-orchestrator (default-OFF strict opt-in; profile inert)
# -----------------------------------------------------------------------------
# The main agent becomes a lean orchestrator: its OWN toolset is restricted to
# read + spawn (FileRead/Glob/Grep/GitDiff/SpawnAgent), and mutation/specialised
# work is delegated to children. This keeps the main context lean and resolves
# the recipe-timing paradox (the spawn call binds the child's constraints
# pre-turn). Requires MAGI_CHILD_RUNNER_TOOLSET=full above so children can mutate.
export MAGI_MAIN_AGENT_PROFILE=orchestrator
# Consume the orchestrator's per-task tool grant: child toolset =
# profile ∩ allowedTools ∩ spawn_cap (the orchestrator's explicit allowedTools
# grant, hard-capped by the session ceiling). Unset => no narrowing.
export MAGI_SPAWN_RECIPE_CAP_ENABLED=1
# Bind recipe packs named per-spawn (recipeRefs) to the child's pre-turn recipe
# resolution, so the recipe's validators/gates/instructions apply to the child.
export MAGI_SPAWN_RECIPE_BIND_ENABLED=1


# -----------------------------------------------------------------------------
# 6. Tools / web / packs / prompt directives (default-OFF strict opt-in)
# -----------------------------------------------------------------------------
export MAGI_FIRST_PARTY_TOOLS_ENABLED=1
export MAGI_FILE_TOOLS_ENABLED=1
# Dashboard pack-builder (custom checks): UI/REST + after-tool deny-on-present
# producer + pre-final gate. Self-host only (transport also 410s on hosted).
export MAGI_DASHBOARD_PACK_AUTHORING_ENABLED=1
export MAGI_FILE_DELIVERY_LIVE_ENABLED=1
export MAGI_DOCUMENT_QA_ENABLED=1
export MAGI_BROWSER_TOOL_ENABLED=1
export MAGI_CODE_ACTION_ENABLED=1
export MAGI_DEFERRED_TOOLS_ENABLED=1
export MAGI_HEADTAIL_TRUNCATION_ENABLED=1
export MAGI_DEEP_WEB_RESEARCH_ENABLED=1
export MAGI_DEEP_WEB_RESEARCH_CROSS_VERIFY=1
export MAGI_TOOL_CONCURRENCY_ENABLED=1
export MAGI_MAX_TOOL_CONCURRENCY=8
export MAGI_MESSAGE_CACHE_ENABLED=1
export MAGI_PROMPT_TRANSFORM_HOOKS_ENABLED=1
# Prompt-directive nudges:
export MAGI_COMPUTE_VIA_CODE_ENABLED=1
export MAGI_FORMAT_ADHERENCE_ENABLED=1
export MAGI_MULTI_FILE_JOIN_ENABLED=1
# Recipe default-pack expansion (safe subset).
export MAGI_RECIPE_DEFAULT_PACKS_EXPANDED=1
# Web search provider stays the default (brave; needs BRAVE_API_KEY). Set
# MAGI_WEB_SEARCH_PROVIDER=serpapi + SERPAPI_API_KEY to switch — left unset on
# purpose so this profile never forces a provider you have no key for.


# -----------------------------------------------------------------------------
# 7. Learning / self-improvement loop
# -----------------------------------------------------------------------------
export MAGI_LEARNING_ENABLED=true
export MAGI_LEARNING_LIVE_ENABLED=1
export MAGI_LEARNING_INJECTION_ENABLED=1
export MAGI_LEARNING_REFLECTION_ENABLED=1
export MAGI_LEARNING_DASHBOARD_ENABLED=1
export MAGI_LEARNING_TELEMETRY_ENABLED=1
export MAGI_SKILL_CURATOR_ENABLED=1
export MAGI_SKILL_CURATOR_SHADOW=0


# -----------------------------------------------------------------------------
# 8. Surfaces / routing
# -----------------------------------------------------------------------------
export MAGI_CLI_ENABLED=1
export MAGI_AUTOPILOT=1
export MAGI_AGENT_LOCAL_CHAT_ROUTE=on
export MAGI_STREAMING_CHAT=on
export MAGI_RUNNER_POLICY_ROUTING_ENABLED=1
# Route DENIAL is audit metadata; hard-blocking it wedges live turns on a
# conservative budget estimate, so keep blocking OFF (matches local_defaults).
export MAGI_RUNNER_POLICY_ROUTE_BLOCKING_ENABLED=0


# -----------------------------------------------------------------------------
# 9. Background tasks ("/workflows"-style) — see PR #732 + PR #742
# -----------------------------------------------------------------------------
# Lets the model fire long-horizon work via RunInBackground and resume the chat
# immediately; completion notes are folded into the next turn. The dispatcher
# uses the durable work-queue store (no in-memory loss on crash), and the inner
# runner reuses ChildRunnerWorkTaskRunner so the task runs in a sandboxed child
# context that shares the session's workspace (Q4=B). The live UX requires ALL
# five flags below — any one off keeps the OFF path byte-identical to default.
#
# Exposure: the RunInBackground native tool is callable by the model.
export MAGI_BACKGROUND_TASK_TOOL_ENABLED=1
# Real store wired: the tool's honest gate sees a SqliteWorkQueueStore and
# enqueues; without this the tool returns blocked_result.
export MAGI_BACKGROUND_TASKS_ATTACHED=1
# Gateway dispatcher tick loop: claim ready tasks, run them, mark terminal.
export MAGI_WORK_QUEUE_EXECUTOR_ENABLED=1
# Upgrade the inner runner from the safe stub to ChildRunnerWorkTaskRunner
# wrapped by InjectingWorkTaskRunner. Without this the queue's terminal
# branch never produces a real summary.
export MAGI_BACKGROUND_LIVE_RUNNER_ENABLED=1
# Drain pending injections into the next chat prompt as a system-note block.
# Without this the completion notes accumulate in the buffer and never reach
# the model — the user sees the board but the chat doesn't surface the result.
export MAGI_BACKGROUND_TASK_INJECT_CONSUMER_ENABLED=1

# Durable work-queue BASE layer. Section 9 enables the background-task surface
# and the dispatcher tick (MAGI_WORK_QUEUE_EXECUTOR_ENABLED) on top of the queue
# store, but the standalone multi-agent work-queue (task board + dispatcher) and
# its read-only HTTP board + terminal-event notifier were never turned on. They
# are merged (P1-P6) and additive; the notifier's default sink is logging-only.
export MAGI_WORK_QUEUE_ENABLED=1
export MAGI_WORK_QUEUE_BOARD_API_ENABLED=1
export MAGI_WORK_QUEUE_NOTIFY_ENABLED=1


# -----------------------------------------------------------------------------
# 10. Subagent governed-turn convergence (default-OFF strict opt-in)
# -----------------------------------------------------------------------------
# Section 5b makes the main agent an orchestrator and binds per-spawn recipe/cap
# grants, but the child still ran the BARE run_async loop — it never went through
# the same governed turn-loop (loop-guard / compaction / evidence / self-review)
# as the parent. These two flags (merged #638/#644/#656/#671) close that gap:
#   * GOVERNED_TURN routes spawned subagents through run_governed_turn.
#   * TOOL_TIGHTEN_ONLY intersects the child's tool set with the parent's
#     effective tools at child-runtime build (no-op when the parent cap is empty).
# OFF is byte-identical to the legacy child path.
export MAGI_SUBAGENT_GOVERNED_TURN_ENABLED=1
export MAGI_SUBAGENT_TOOL_TIGHTEN_ONLY_ENABLED=1


# -----------------------------------------------------------------------------
# 11. Routing / model-selection capability (default-OFF strict opt-in; merged)
# -----------------------------------------------------------------------------
# Description-based LLM recipe + worker routing (replaces keyword/membership
# inference) and key-aware child-spawn route filtering. All merged (#599/#610 +
# #632); key-aware filtering fails OPEN when no provider key is configured, so it
# never strands a no-key setup.
export MAGI_RECIPE_ROUTING_LLM_ENABLED=1
export MAGI_WORKER_ROUTING_LLM_ENABLED=1
export MAGI_KEY_AWARE_MODEL_ROUTES_ENABLED=1


# -----------------------------------------------------------------------------
# 12. Context compaction — actually summarize instead of silent prefix drop
# -----------------------------------------------------------------------------
# Section 4 turns on MAGI_CONTEXT_COMPACTION_ENABLED, but with NONE of the
# sub-flags the compactor just tail-drops the prefix with no summary. These make
# compaction real: an LLM summary of the dropped span (anchored/incremental on
# the prior summary), a real-prompt-token budget signal instead of the char
# estimate, a deterministic old-tool-output prune pre-tier, and a working manual
# /compact. OFF for each is byte-identical. COST NOTE: SUMMARIZE spends one
# session-model call per compaction event.
export MAGI_COMPACTION_SUMMARIZE_ENABLED=1
export MAGI_COMPACTION_ANCHORED_SUMMARY_ENABLED=1
export MAGI_COMPACTION_REAL_TOKENS_ENABLED=1
export MAGI_COMPACTION_TOOL_PRUNE_ENABLED=1
export MAGI_COMPACTION_MANUAL_ENABLED=1


# -----------------------------------------------------------------------------
# 13. Guidance-only prompt blocks (default-OFF; NOT enforcing — pure upside)
# -----------------------------------------------------------------------------
# Each appends a prompt block in build_cli_instruction. None block or gate a
# turn; they only shape the model's behavior. SEARCH_RULES self-suppresses
# unless web tools are available (BRAVE_API_KEY AND FIRECRAWL_API_KEY).
export MAGI_AUTOMATION_METHODOLOGY_ENABLED=1
export MAGI_RESEARCH_METHODOLOGY_ENABLED=1
export MAGI_CODING_CONTEXT_ENABLED=1
export MAGI_PROMPT_EXAMPLES_ENABLED=1
export MAGI_PROMPT_REDFLAGS_ENABLED=1
export MAGI_PROMPT_SEARCH_RULES_ENABLED=1
# Synthesize per-tool 'Use when / Do NOT use when' guidance into gate5b ADK tool
# descriptions (serve path); byte-identical docstrings when off.
export MAGI_TOOL_USAGE_GUIDANCE_ENABLED=1


# -----------------------------------------------------------------------------
# 14. Misc additive capability (default-OFF strict opt-in)
# -----------------------------------------------------------------------------
# Persistent-interpreter CodeAct tool (namespace survives across calls).
export MAGI_PERSISTENT_PYTHON_ENABLED=1
# A normal-mode parent yields a READ-ONLY child memory mode (child reads parent
# workspace memory, never writes back); OFF keeps children incognito.
export MAGI_CHILD_MEMORY_INHERIT_ENABLED=1
# Per-session JSONL debug transcripts (turn stages / tool calls / spawns /
# messages) under the observability home. Pure observability.
export MAGI_SESSION_TRANSCRIPT_ENABLED=1
# Production goal-nudge: one bounded continuation when the driver detects a clean
# stop short of the stated goal. OFF injects goal_nudge=None (byte-identical).
export MAGI_GOAL_NUDGE_ENABLED=1
# CC-style user hooks (self-host / local CLI ONLY — never hosted multi-tenant,
# since command hooks run operator-supplied `bash -c`). Loads ~/.magi/settings.json
# + <workspace>/.magi/settings.json and bridges PreToolUse/PostToolUse callbacks.
export MAGI_USER_HOOKS_ENABLED=1


# -----------------------------------------------------------------------------
# 15. Live channel watchers — ARMED, awaiting credentials (self-host only)
# -----------------------------------------------------------------------------
# These are pure GATES, not switches that force a connection. The boundary
# modules (channels/discord_live.py, channels/slack_live.py) are import-clean by
# design — no `discord`/`slack_sdk`/`requests`/`httpx` at top level — so setting
# the flag NEVER crashes startup even without the optional extras installed. The
# live path additionally requires a token (and for inbound, an injected provider
# port / Socket-Mode extra); with none present the watcher is fail-closed (not
# built) and the send path is fail-soft (never raises). So enabling here means
# "ready the moment the operator drops in credentials" rather than two switches.
#   * Slack OUTBOUND works out-of-box on stdlib urllib (no extra) once
#     SLACK_BOT_TOKEN + this gate are set. Inbound Socket Mode needs [slack].
#   * Discord ships NO bundled provider — it stays inert until the operator/Track-F
#     daemon injects a DiscordProviderPort; the flag is import-safe regardless.
export MAGI_CHANNEL_LIVE_SLACK=1
export MAGI_CHANNEL_LIVE_DISCORD=1


# =============================================================================
# DELIBERATELY NOT SET HERE (documented so the omission is a decision, not a miss)
# =============================================================================
# Measure-FP-first (LLM-judge egress BLOCKS; each = one critic model pass):
#   MAGI_VERIFY_ANSWER_QUALITY / _CLAIM_CITATION / _COMPLETION_EVIDENCE /
#   _OUTPUT_PURITY / _PARALLEL_RESEARCH / _PRE_REFUSAL / _RESOURCE_CLAIM /
#   _RESPONSE_LANGUAGE / _TASKBOARD_COMPLETION, and MAGI_SOURCE_LEDGER_EVIDENCE_GATE.
#   Consistent with this profile's block-aggressive stance, but enable behind a
#   measured FP pass. The deterministic two (_RESPONSE_LANGUAGE needs a policy,
#   _TASKBOARD_COMPLETION) are the cheapest/safest to add first.
# Needs ON-path re-verify (the #641 default-ON-flip-broke-~10-policy-tests pair):
#   MAGI_KERNEL_RECIPE_PACKS_ENABLED / MAGI_KERNEL_ROLE_PROVIDES_ENABLED.
# Inert without a producer / installed external pack:
#   MAGI_SHACL_VERIFIER_ENABLED (needs compiler + authored rules),
#   MAGI_SHACL_COMPILER_ENABLED / MAGI_CUSTOMIZE_SEAM_SPEC_ENABLED (endpoints only),
#   MAGI_GROUNDED_ANSWER_GUARD_ENABLED (GAIA-harness metadata only),
#   MAGI_KERNEL_RECIPE_ENTRY_POINTS_ENABLED / MAGI_KERNEL_VERIFIER_ENTRY_POINTS_ENABLED
#   (import external publisher modules — self-host trust; hosted floor must NEVER).
# Hosted-ops decision (local is harmless; hosted needs obs-home PVC write + soak):
#   MAGI_SERVE_EVIDENCE_ENABLED.
