# -----------------------------------------------------------------------------
export MAGI_FIRST_PARTY_TOOLS_ENABLED=1
export MAGI_FILE_TOOLS_ENABLED=1
# Dashboard pack-builder (custom checks): UI/REST + after-tool deny-on-present
# producer + pre-final gate. Self-host only (transport also 410s on hosted).
export MAGI_DASHBOARD_PACK_AUTHORING_ENABLED=1
export MAGI_FILE_DELIVERY_LIVE_ENABLED=1
export MAGI_DOCUMENT_QA_ENABLED=1
export MAGI_BROWSER_TOOL_ENABLED=1
export MAGI_DEEP_WEB_RESEARCH_ENABLED=1
export MAGI_DEEP_WEB_RESEARCH_CROSS_VERIFY=1
export MAGI_TOOL_CONCURRENCY_ENABLED=1
export MAGI_MAX_TOOL_CONCURRENCY=8
export MAGI_MESSAGE_CACHE_ENABLED=1
# Prompt-directive nudges:
export MAGI_COMPUTE_VIA_CODE_ENABLED=1
export MAGI_FORMAT_ADHERENCE_ENABLED=1
# Recipe default-pack expansion (safe subset).
export MAGI_RECIPE_DEFAULT_PACKS_EXPANDED=1
# Web search provider stays the default (brave; needs BRAVE_API_KEY). Set
# MAGI_WEB_SEARCH_PROVIDER=serpapi + SERPAPI_API_KEY to switch — left unset on
# purpose so this profile never forces a provider you have no key for.


# -----------------------------------------------------------------------------
# 7. Learning / self-improvement loop
# -----------------------------------------------------------------------------
export MAGI_LEARNING_ENABLED=true
export MAGI_LEARNING_LIVE_ENABLED=1
export MAGI_LEARNING_INJECTION_ENABLED=1
export MAGI_LEARNING_REFLECTION_ENABLED=1
export MAGI_LEARNING_DASHBOARD_ENABLED=1
export MAGI_LEARNING_TELEMETRY_ENABLED=1
export MAGI_SKILL_CURATOR_ENABLED=1
export MAGI_SKILL_CURATOR_SHADOW=0

# First-run onboarding wizard: when no provider is configured, the dashboard
# shows a setup wizard (provider + API key + model) instead of requiring a
