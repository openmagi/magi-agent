# =============================================================================
# Magi Agent — "full-ON dogfood" environment profile
# =============================================================================
#
# Operator decision: the sole operator wants EVERY intended governance / harness
# module to actually RUN, on BOTH the local CLI ("magi agent", cli/engine path)
# AND the canary/hosted serve (gate5b path).
#
# This file is CONFIG, not a code-default change. It flips NO repo *.py default.
# Sourcing it sets explicit env values; un-setting it (a fresh shell) restores
# byte-identical default-OFF behavior, so the default-OFF-presuming test suite
# stays green.
#
# USAGE
#   Local CLI / serve:   set -a; source scripts/dogfood-full-on.env; set +a
#                        magi agent ...        # or: magi-agent serve ...
#   Canary / hosted:     inject these as the pod/container env (the
#                        MAGI_GATE5B_GOVERNANCE_ENABLED=1 line is what makes the
#                        gate5b serving path run the same governance as the CLI).
#
# SEMANTICS PRIMER (why two shapes of "on")
#   * profile-aware flags (kind="profile_bool", env._runtime_feature_enabled):
#     unset => ON in the full profile, OFF under MAGI_RUNTIME_PROFILE=safe/eval.
#     Setting MAGI_RUNTIME_PROFILE=full (below) already turns these ON; we ALSO
#     set each one explicitly so the value is self-documenting and survives any
#     reader that does not go through the local_defaults setdefault overlay.
#   * strict opt-in flags (kind="bool", default-OFF): MAGI_RUNTIME_PROFILE NEVER
#     auto-enables these. The profile is inert for them — they MUST be listed
#     here explicitly. This is the real "turn everything on" payload.
#
# RISK NOTES (set ON anyway, per the operator's explicit "turn everything on")
#   * MAGI_DOCUMENT_AUTHORING_COVERAGE=block — HARD-BLOCKS a document turn whose
#     DocumentCoverage record is not "pass" (highest false-block risk). Use
#     "advisory" instead of "block" to measure first.
#   * MAGI_SELF_REVIEW_ENABLED=1 (+LIVE) — spends an extra model pass after each
#     turn (latency + token cost).
#   * MAGI_RESEARCH_GOVERNANCE_MODE=enforce — one bounded corrective re-prompt on
#     the deterministic cited-without-source class (near-zero FP; still a re-run).
#   * MAGI_FACT_GROUNDING_VERIFICATION_ENABLED=1 / MAGI_GA_DELIVERABLE_GATE_ENABLED=1
#     — can BLOCK a final answer that asserts an ungrounded specific value / ships
#     no artifact receipt.
#   * MAGI_CHILD_RUNNER_LIVE_ENABLED=1 — real model-backed sub-agents (cost).
#
# =============================================================================


# -----------------------------------------------------------------------------
# 0. Profile selector
# -----------------------------------------------------------------------------
# "full" is any value NOT in {safe,off,minimal,conservative,eval}; it makes
# runtime/local_defaults.apply_local_full_runtime_defaults() apply the
# profile-opt-out set and makes every profile_bool flag resolve ON. We keep it
# explicit AND list each downstream flag below so nothing is implicit.
export MAGI_RUNTIME_PROFILE=full
export MAGI_AGENT_LOCAL_FULL_RUNTIME_DEFAULTS=1


# -----------------------------------------------------------------------------
# 1. Strict opt-in GOVERNANCE / VERIFICATION gates (default-OFF; profile inert)
#    These are the heart of "turn everything on". None default ON in any profile.
# -----------------------------------------------------------------------------
# Gate5b serving-path governance (G1). Makes the canary/hosted serve attach the
# SAME control-plane plugin + run the SAME pre-final fact-grounding check as the
# local CLI. Without this line governance is cli/engine-only.
export MAGI_GATE5B_GOVERNANCE_ENABLED=1

# Live evidence gate: block an answer asserting a specific numeric/identifier
# value not present in the opened-source corpus (cli/engine AND, via the line
# above, gate5b).
export MAGI_FACT_GROUNDING_VERIFICATION_ENABLED=1

# GA deliverable completion gate: an artifact receipt must exist before finalise.
export MAGI_GA_DELIVERABLE_GATE_ENABLED=1

# Evidence-grounded critic gate before chat egress.
export MAGI_EGRESS_GATE_ENABLED=1

# Periodic in-context facts survey + plan refresh injected into the live loop.
export MAGI_FACTS_REPLAN_ENABLED=1
export MAGI_FACTS_REPLAN_INTERVAL=4
export MAGI_FACTS_REPLAN_MAX_PER_TURN=5

# Live-SWE-style tool-synthesis nudge ("create your own tools" recipe block).
export MAGI_TOOL_SYNTHESIS_NUDGE_ENABLED=1

# Document-authoring coverage gate. RISK: "block" hard-blocks failed-coverage
# document turns. Operator wants real governance -> block (use "advisory" to
# measure FP first). Legacy truthy ("1") also means block.
export MAGI_DOCUMENT_AUTHORING_COVERAGE=block

# Research governance. "enforce" = one bounded re-prompt on the deterministic
# cited-without-source class (the local full profile only sets "audit").
export MAGI_RESEARCH_GOVERNANCE_MODE=enforce

# Research_fact cross-check guidance brief + <web_research> prompt block
# (effective only with BRAVE_API_KEY + FIRECRAWL_API_KEY present).
export MAGI_RESEARCH_FACT_GUIDANCE_ENABLED=1

# Cross-verification gate over spawned-agent results.
export MAGI_CROSS_VERIFY_ENABLED=1

# First-pass sub-step enumeration nudge.
export MAGI_STEP_DECOMPOSITION_ENABLED=1

# Self-introspection InspectSelfEvidence tool + durable evidence ledgers.
# (SELF_INTROSPECTION / EVIDENCE_LEDGER_LIFECYCLE are profile-ON; reaffirmed in
#  section 4. The ledger DIR below is the strict opt-in that makes ledgers
#  durable on disk rather than lean in-memory only.)
export MAGI_EVIDENCE_LEDGER_DIR=.openmagi/evidence-ledgers


# -----------------------------------------------------------------------------
# 2. Self-review (default-OFF strict opt-in; cost noted above)
# -----------------------------------------------------------------------------
export MAGI_SELF_REVIEW_ENABLED=1
export MAGI_SELF_REVIEW_SHADOW=0
export MAGI_SELF_REVIEW_PIPELINE_ENABLED=1
export MAGI_SELF_REVIEW_LIVE_ENABLED=1
export MAGI_SELF_REVIEW_TELEMETRY_ENABLED=1

# Max-steps brake control-plane seam.
export MAGI_MAX_STEPS_BRAKE_ENABLED=1


# -----------------------------------------------------------------------------
# 3. MEMORY subsystem (master is strict default-OFF and NOT profile-aware, so
#    the full profile leaves it OFF — it MUST be turned on explicitly here).
#    Sub-flags follow the master; the cost/multi-tenancy opt-ins (soul_write,
#    vector_search, qmd auto-register) stay OFF under master-on unless set, so
#    we set the ones the operator wants ("everything on") explicitly.
# -----------------------------------------------------------------------------
export MAGI_MEMORY_ENABLED=1
export MAGI_MEMORY_WRITE_ENABLED=1
export MAGI_MEMORY_RECALL_ENABLED=1
export MAGI_MEMORY_COMPACTION_ENABLED=1
export MAGI_MEMORY_PROJECTION_ENABLED=1
export MAGI_MEMORY_WRITE_READINESS_ENABLED=1
export MAGI_MEMORY_MODE_ROUTING_ENABLED=1
export MAGI_MEMORY_QMD_LIVE_ENABLED=1
# Master-on opt-ins (explicit, stay OFF otherwise):
export MAGI_MEMORY_VECTOR_SEARCH=1
export MAGI_MEMORY_PREFER_LOCAL_SEARCH=1
export MAGI_MEMORY_LOCAL_DEV=1


# -----------------------------------------------------------------------------
# 4. Coding / resilience harness (profile-aware default-ON: reaffirmed explicit)
#    These are ON in the full profile already; setting them keeps the file the
#    single readable source of truth and immune to setdefault-bypass readers.
# -----------------------------------------------------------------------------
export MAGI_EDIT_FUZZY_MATCH_ENABLED=1
export MAGI_EDIT_FORMAT_ON_WRITE_ENABLED=1
export MAGI_EDIT_RETRY_REFLECTION_ENABLED=1
export MAGI_CODING_REPAIR_LOOP_ENABLED=1
export MAGI_LSP_DIAGNOSTICS_ENABLED=1
export MAGI_RIPGREP_ENABLED=1
export MAGI_APPLY_PATCH_ENABLED=1
export MAGI_LOOP_GUARD_ENABLED=1
export MAGI_ERROR_RECOVERY_ENABLED=1
export MAGI_OUTPUT_CONTINUATION_ENABLED=1
export MAGI_CONTEXT_COMPACTION_ENABLED=1
export MAGI_SELF_INTROSPECTION_ENABLED=1
export MAGI_EVIDENCE_LEDGER_LIFECYCLE_ENABLED=1
export MAGI_EVIDENCE_COMPLETION_GATE_ENABLED=1
export MAGI_PROVIDER_REPAIR_ENABLED=1
export MAGI_MODEL_AWARE_PROMPTS_ENABLED=1
export MAGI_TRUSTED_LOCAL_SHELL_ENABLED=1


# -----------------------------------------------------------------------------
# 5. GA live + workflow + child runner + scheduler + observability
# -----------------------------------------------------------------------------
export MAGI_GA_LIVE_ENABLED=1
export MAGI_WORKFLOW_EXECUTOR_ENABLED=1
export MAGI_CHILD_RUNNER_LIVE_ENABLED=1
export MAGI_CHILD_RUNNER_TOOLSET=readonly
export MAGI_SCHEDULER_EXECUTOR_ENABLED=1
export MAGI_SCHEDULER_SHADOW=0
export MAGI_GOAL_LOOP_ENABLED=1
export MAGI_OBSERVABILITY_ENABLED=1
export MAGI_OBS_HOME=.openmagi
export MAGI_SESSION_PERSISTENCE_ENABLED=1


# -----------------------------------------------------------------------------
# 6. Tools / web / packs / prompt directives (default-OFF strict opt-in)
# -----------------------------------------------------------------------------
export MAGI_FIRST_PARTY_TOOLS_ENABLED=1
export MAGI_FILE_TOOLS_ENABLED=1
export MAGI_FILE_DELIVERY_LIVE_ENABLED=1
export MAGI_DOCUMENT_QA_ENABLED=1
export MAGI_BROWSER_TOOL_ENABLED=1
export MAGI_CODE_ACTION_ENABLED=1
export MAGI_DEFERRED_TOOLS_ENABLED=1
export MAGI_HEADTAIL_TRUNCATION_ENABLED=1
export MAGI_DEEP_WEB_RESEARCH_ENABLED=1
export MAGI_DEEP_WEB_RESEARCH_CROSS_VERIFY=1
export MAGI_TOOL_CONCURRENCY_ENABLED=1
export MAGI_MAX_TOOL_CONCURRENCY=8
export MAGI_MESSAGE_CACHE_ENABLED=1
export MAGI_PROMPT_TRANSFORM_HOOKS_ENABLED=1
# Prompt-directive nudges:
export MAGI_COMPUTE_VIA_CODE_ENABLED=1
export MAGI_FORMAT_ADHERENCE_ENABLED=1
export MAGI_MULTI_FILE_JOIN_ENABLED=1
# Recipe default-pack expansion (safe subset).
export MAGI_RECIPE_DEFAULT_PACKS_EXPANDED=1
# Web search provider stays the default (brave; needs BRAVE_API_KEY). Set
# MAGI_WEB_SEARCH_PROVIDER=serpapi + SERPAPI_API_KEY to switch — left unset on
# purpose so this profile never forces a provider you have no key for.


# -----------------------------------------------------------------------------
# 7. Learning / self-improvement loop
# -----------------------------------------------------------------------------
export MAGI_LEARNING_ENABLED=true
export MAGI_LEARNING_LIVE_ENABLED=1
export MAGI_LEARNING_INJECTION_ENABLED=1
export MAGI_LEARNING_REFLECTION_ENABLED=1
export MAGI_LEARNING_DASHBOARD_ENABLED=1
export MAGI_LEARNING_TELEMETRY_ENABLED=1
export MAGI_SKILL_CURATOR_ENABLED=1
export MAGI_SKILL_CURATOR_SHADOW=0


# -----------------------------------------------------------------------------
# 8. Surfaces / routing
# -----------------------------------------------------------------------------
export MAGI_CLI_ENABLED=1
export MAGI_AUTOPILOT=1
export MAGI_AGENT_LOCAL_CHAT_ROUTE=on
export MAGI_STREAMING_CHAT=on
export MAGI_RUNNER_POLICY_ROUTING_ENABLED=1
# Route DENIAL is audit metadata; hard-blocking it wedges live turns on a
# conservative budget estimate, so keep blocking OFF (matches local_defaults).
export MAGI_RUNNER_POLICY_ROUTE_BLOCKING_ENABLED=0
