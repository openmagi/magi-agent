# Magi Configuration
# Copy this file to magi-agent.yaml and fill in your values.

# LLM Provider
# Default is a local OpenAI-compatible server so Docker Compose can run without
# a hosted provider key. Change provider/model/apiKey for Anthropic, OpenAI, or
# Google when you want a hosted model.
llm:
  provider: openai-compatible  # anthropic | openai | google | openai-compatible
  model: ${CORE_AGENT_MODEL}
  baseUrl: ${OPENAI_BASE_URL}
  apiKey: ${OPENAI_API_KEY}    # optional; leave blank for no-auth local servers
  capabilities:
    contextWindow: 65536
    maxOutputTokens: 4096
    supportsThinking: false
    inputUsdPerMtok: 0
    outputUsdPerMtok: 0

# Hosted provider example:
# llm:
#   provider: anthropic
#   model: claude-sonnet-4-6
#   apiKey: ${ANTHROPIC_API_KEY}

# Local/self-hosted HTTP API token.
# Use this in Magi App. Do not put your provider API key in the browser.
server:
  gatewayToken: ${MAGI_AGENT_SERVER_TOKEN}

# Channels (optional — enable the ones you need)
# channels:
#   telegram:
#     token: ${TELEGRAM_BOT_TOKEN}
#   discord:
#     token: ${DISCORD_BOT_TOKEN}
#   webhook:
#     url: https://my-app.com/webhook
#     secret: ${WEBHOOK_SECRET}

# Hooks
hooks:
  builtin:
    factGrounding: true        # Hallucination prevention
    preRefusalVerifier: true   # Prevents unnecessary refusals
    workspaceAwareness: true   # Auto-injects filesystem context
    sessionResume: true        # Seeds context on session resume
    discipline: false          # TDD/git enforcement (default off)
  # custom:
  #   - path: ./hooks/my-hook.ts
  #     event: beforeCommit
  #     priority: 80

# Memory (Hipocampus)
memory:
  enabled: true
  compaction: true             # 5-level auto-compaction

# Workspace
workspace: ./workspace
identity:
  name: "Magi"
  instructions: "You are a helpful coding assistant."
