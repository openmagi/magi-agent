{
  "name": "magi-agent",
  "version": "0.2.0",
  "description": "Autonomous task runtime with agentic interaction. Open-source, multi-provider, programmable.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "magi-agent": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "cli": "tsx src/cli/index.ts",
    "desktop:dev": "npm --prefix apps/desktop run dev",
    "desktop:build": "npm --prefix apps/desktop run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "ai-agent",
    "autonomous",
    "agentic",
    "llm",
    "claude",
    "openai",
    "gemini",
    "task-runtime",
    "hooks",
    "multi-provider"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/openmagi/magi-agent.git"
  },
  "homepage": "https://github.com/openmagi/magi-agent",
  "bugs": {
    "url": "https://github.com/openmagi/magi-agent/issues"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "discord.js": "^14.26.3",
    "ulid": "^2.3.0",
    "yaml": "^2.8.3"
  },
  "optionalDependencies": {
    "@tobilu/qmd": "*",
    "docx": "^9.0.0",
    "exceljs": "^4.4.0",
    "pdfkit": "^0.16.0",
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/pdfkit": "^0.17.6",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  }
}
