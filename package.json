{
  "name": "magi-agent",
  "version": "0.2.0",
  "description": "Autonomous task runtime with agentic interaction. Open-source, multi-provider, programmable.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "magi-agent": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run web:build",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "cli": "tsx src/cli/index.ts",
    "web:build": "vite build --config apps/web/vite.config.ts",
    "web:check": "tsc -p apps/web/tsconfig.json --noEmit",
    "web:dev": "vite --config apps/web/vite.config.ts --host 127.0.0.1",
    "desktop:dev": "npm --prefix apps/desktop run dev",
    "desktop:build": "npm --prefix apps/desktop run build",
    "research:eval": "node scripts/research-parity-eval.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit && npm run web:check",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "ai-agent",
    "autonomous",
    "agentic",
    "llm",
    "claude",
    "openai",
    "gemini",
    "task-runtime",
    "hooks",
    "multi-provider"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/openmagi/magi-agent.git"
  },
  "homepage": "https://github.com/openmagi/magi-agent",
  "bugs": {
    "url": "https://github.com/openmagi/magi-agent/issues"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "discord.js": "^14.26.3",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.2.4",
    "ulid": "^2.3.0",
    "yaml": "^2.8.3",
    "zustand": "^5.0.13"
  },
  "optionalDependencies": {
    "@tobilu/qmd": "*",
    "docx": "^9.0.0",
    "exceljs": "^4.4.0",
    "pdfkit": "^0.16.0",
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vite": "^7.1.7",
    "vitest": "^2.1.2"
  }
}
