        {
          "type": "turn_start",
          "eventId": "evt-hidden-turn",
          "turnId": "turn-hidden"
        },
        {
          "type": "thinking_delta",
          "eventId": "evt-hidden-thinking",
          "delta": "hidden chain trace SECRET_DO_NOT_PROJECT"
        }
      ]
    },
    {
      "id": "raw_tool_args_results_leak",
